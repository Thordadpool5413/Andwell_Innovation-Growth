NODE_ENV=production

# Hostinger usually provides PORT at runtime. Do not set PORT manually unless Hostinger specifically gives you a required application port.
# PORT=3000

CRAWL_MAX_PAGES_PER_SITE=24
CRAWL_TIMEOUT_MS=12000
CIH_DATA_DIR=.data

# Optional Supabase persistence. If both values are set, the app uses Supabase before MongoDB or the local JSON store.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional MongoDB persistence. If MONGODB_URI is set, the app uses MongoDB instead of the local JSON store.
MONGODB_URI=
MONGODB_DB=andwell_innovation

# Optional OpenAI extraction. If OPENAI_API_KEY is set, /api/analyze adds AI extraction, healthcare reasoning, and sales positioning.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
